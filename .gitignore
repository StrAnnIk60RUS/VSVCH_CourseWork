# Dependencies
node_modules/

# Environment and secrets (track only templates / examples)
.env
.env.*
!.env.example
!.env.*.example

# Build output
dist/
dist-ssr/
build/
out/

# TypeScript
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Caches and tool output
.cache/
.parcel-cache/
.turbo/
.vite/
coverage/
.nyc_output/
.eslintcache

# Vite (occasional generated config snapshots)
vite.config.*.timestamp-*

# Local databases (Sequelize migrations stay tracked)
*.db
*.db-journal
*.sqlite
*.sqlite3

# AI / LLM assistants (Cursor, editor prompts) — not application source
.cursor/
.cursorrules
.cursorignore
.windsurfrules

# Other IDEs
.idea/
*.swp
*.swo
*~

# VS Code — personal settings ignored; share extensions list
.vscode/*
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows / legacy Visual Studio artifacts
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
